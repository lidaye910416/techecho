# MiniMax API Key (必需 — 用于 TTS 语音合成和 AI 分析)
MINIMAX_API_KEY=your_api_key_here

# 微信小程序配置 (正式发布时填写)
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here

# ============ 微信云托管对象存储配置 (可选) ============
# 用于将音频文件上传到云存储，解决镜像部署时文件丢失问题
# 获取方式：微信云托管控制台 -> 环境 -> 对象存储 -> 访问密钥
# 注意：未配置时将使用本地存储（镜像内）

# 腾讯云 SecretId (从微信云托管控制台获取)
# WECHAT_CLOUD_SECRET_ID=your_secret_id

# 腾讯云 SecretKey (从微信云托管控制台获取)
# WECHAT_CLOUD_SECRET_KEY=your_secret_key

# 对象存储桶名称 (格式: techecho-audio-12345678)
# WECHAT_CLOUD_BUCKET=your_bucket_name

# 区域 (默认: ap-shanghai)
# WECHAT_CLOUD_REGION=ap-shanghai

# 环境ID (格式: test1-258814-7)
# WECHAT_CLOUD_ENV=test1-258814-7

# 可选配置
# DATABASE_URL=sqlite:///data/database.db
# BASE_URL=http://localhost:8001
