# MiniMax API Key (必需 — 用于 TTS 语音合成和 AI 分析)
MINIMAX_API_KEY=your_api_key_here

# 微信小程序配置 (必需 — 用于微信云存储 API)
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here

# ============ 微信云托管对象存储配置 ============
# 存储桶 ID: 7072-prod-d9g7e5osy7b5e7a9c-1433977056
# 环境 ID: prod-d9g7e5osy7b5e7a9c

# 微信云托管环境 ID (默认已有)
WECHAT_CLOUD_ENV=prod-d9g7e5osy7b5e7a9c

# 微信 Access Token (通过 WECHAT_APPID + WECHAT_SECRET 获取)
# 需要调用 https://api.weixin.qq.com/cgi-bin/token 获取
# WECHAT_ACCESS_TOKEN=your_access_token_here

# 可选配置
# DATABASE_URL=sqlite:///data/database.db
# BASE_URL=http://localhost:8001

# ============ MySQL 数据库配置 (微信云托管) ============
# 用于数据持久化，替代 SQLite（容器重建后数据不丢失）
# 从微信云托管控制台获取连接信息
MYSQL_HOST=your_mysql_host
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=techecho
