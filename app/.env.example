# TechEcho 小程序 API 配置
# 复制此文件为 .env 后填入实际地址

# ===== 云托管配置 =====
# 是否使用微信云托管 (true/false)
# true:  使用 wx.cloud.callContainer 调用云托管服务
# false: 使用普通 Taro.request 调用 API
TARO_APP_USE_CLOUD=true

# ===== 微信云托管配置（当 USE_CLOUD=true 时需要填写） =====
# 云托管环境 ID（在云托管控制台查看）
TARO_APP_CLOUD_ENV=your-environment-id
# 云托管服务名称（在云托管控制台查看）
TARO_APP_CLOUD_SERVICE=your-service-name

# ===== 普通 API 配置（当 USE_CLOUD=false 时使用） =====
# API 地址（用于 H5 开发或非云托管场景）
# 开发环境
# TARO_APP_API_BASE=http://localhost:8000
# 生产环境
# TARO_APP_API_BASE=https://your-domain.sh.run.tcloudbase.com
